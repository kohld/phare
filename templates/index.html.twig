{% extends 'base.html.twig' %}

{% block title %}{% if page > 1 %}Page {{ page }} — {% endif %}{{ title }}{% endblock %}

{% block content %}
<h1>{{ title }}</h1>
<p>{{ description|default('') }}</p>

{% if posts is empty %}
    <p>No posts yet.</p>
{% else %}
    <ul style="list-style: none; padding: 0;">
        {% for post in posts %}
        <li style="margin-bottom: 2rem;">
            <h2 style="margin-bottom: 0.25rem;"><a href="{{ base_path }}{{ post.url }}">{{ post.title }}</a></h2>
            <div class="post-meta">
                {{ post.date|date(date_format|default('F j, Y')) }}
                {% if post.category %} · <a href="{{ base_path }}/category/{{ post.category|lower }}/">{{ post.category }}</a>{% endif %}
            </div>
            <p>{{ post.excerpt }}</p>
            {% if post.tags %}
                <div>
                    {% for tag in post.tags %}<a class="tag" href="{{ base_path }}/tag/{{ tag|lower }}/">{{ tag }}</a> {% endfor %}
                </div>
            {% endif %}
        </li>
        {% endfor %}
    </ul>

    {% if total_pages > 1 %}
    <nav style="margin-top: 2rem;">
        {% if page > 1 %}<a href="{% if page == 2 %}{{ base_path }}/{% else %}{{ base_path }}/page/{{ page - 1 }}/{% endif %}">← Newer</a> {% endif %}
        <span>Page {{ page }} of {{ total_pages }}</span>
        {% if page < total_pages %} <a href="{{ base_path }}/page/{{ page + 1 }}/">Older →</a>{% endif %}
    </nav>
    {% endif %}
{% endif %}
{% endblock %}
