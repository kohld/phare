{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} — {{ title }}{% endblock %}
{% block description %}{{ post.excerpt }}{% endblock %}

{% block content %}
<article>
    <h1>{{ post.title }}</h1>
    <div class="post-meta">
        {{ post.date|date(date_format|default('F j, Y')) }}
        {% if post.category %} · <a href="{{ base_path }}/category/{{ post.category|lower }}/">{{ post.category }}</a>{% endif %}
    </div>

    <div class="post-content">
        {{ post.content|raw }}
    </div>

    {% if post.tags %}
    <div style="margin-top: 2rem;">
        {% for tag in post.tags %}<a class="tag" href="{{ base_path }}/tag/{{ tag|lower }}/">{{ tag }}</a> {% endfor %}
    </div>
    {% endif %}
</article>

<p style="margin-top: 2rem;"><a href="{{ base_path }}/">← Back to index</a></p>
{% endblock %}
